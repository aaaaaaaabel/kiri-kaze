# Firebase 環境變數設定
# 
# 如何取得這些金鑰：
# 1. 前往 Firebase Console: https://console.firebase.google.com/
# 2. 選擇或建立專案
# 3. 點擊專案設定 (Project Settings) > 一般 (General)
# 4. 滾動到「您的應用程式」區塊
# 5. 選擇 Web 應用程式 (Web app) 或建立新的 Web 應用程式
# 6. 複製 Firebase 設定物件中的值
#
# 將此檔案複製為 .env 並填入真實的 Firebase 金鑰

# Firebase API Key
NUXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here

# Firebase Auth Domain (格式: your-project.firebaseapp.com)
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

# Firebase Project ID
NUXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id

# Firebase Storage Bucket (格式: your-project.appspot.com)
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Firebase Messaging Sender ID
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# Firebase App ID
NUXT_PUBLIC_FIREBASE_APP_ID=your_app_id
